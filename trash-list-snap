#!/bin/bash
echo "=== Snap Codium Trash ==="
# Use shopt to handle non-matching globs
shopt -s nullglob
snap_trash_dirs=($HOME/snap/*/*/.local/share/Trash/files/)
shopt -u nullglob

# Deduplicate the directories
unique_dirs=($(printf '%s\n' "${snap_trash_dirs[@]}" | sort -u))

if [ ${#unique_dirs[@]} -gt 0 ]; then
  for dir in "${unique_dirs[@]}"; do
    for file in "$dir"/*; do
      echo "$file"
    done
  done
else
  echo "No snap trash found"
fi
